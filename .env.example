# Copy to .env on the VM and replace every placeholder before starting Nado.
# Generate the admin token with: openssl rand -base64 48
NADO_TOKEN=replace-with-a-long-random-admin-token

# Optional during rotation only. Example:
# NADO_ADMIN_TOKENS=old-admin-token,new-admin-token

# Public URL that browsers and remote workers can reach.
# Use https://nado.example.com behind a reverse proxy, or bracket IPv6 literals:
# http://[2001:db8::10]:8765
NADO_PUBLIC_CONTROL_URL=https://nado.example.com

# Container host port for the production compose file.
NADO_DOCKER_PORT=8765

# Production deployments should use SQLite. JSON remains the local/dev default.
NADO_STORE=sqlite

# Bind Docker's published port. Use :: only when the Azure VM and Docker daemon
# are configured for IPv6 and the Azure NSG allows the inbound port.
NADO_DOCKER_HOST_IP=0.0.0.0
